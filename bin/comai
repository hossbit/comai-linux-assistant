#!/usr/bin/env bash
set -euo pipefail

COMAI_BIN_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
COMAI_ROOT_DIR="$(cd "$(dirname "$COMAI_BIN_PATH")/.." && pwd)"

# shellcheck source=../lib/comai/config.sh
. "$COMAI_ROOT_DIR/lib/comai/config.sh"
# shellcheck source=../lib/comai/args.sh
. "$COMAI_ROOT_DIR/lib/comai/args.sh"
# shellcheck source=../lib/comai/context.sh
. "$COMAI_ROOT_DIR/lib/comai/context.sh"
# shellcheck source=../lib/comai/local-checks.sh
. "$COMAI_ROOT_DIR/lib/comai/local-checks.sh"
# shellcheck source=../lib/comai/model-conditions.sh
. "$COMAI_ROOT_DIR/lib/comai/model-conditions.sh"
# shellcheck source=../lib/comai/ai.sh
. "$COMAI_ROOT_DIR/lib/comai/ai.sh"

comai_main() {
  local text dir_context files prompt

  comai_load_config

  if [[ "$#" -eq 0 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    comai_usage
    return 0
  fi

  comai_parse_args "$@" || return 1
  comai_detect_mentioned_files

  text="$(comai_join_args "${REQUEST_ARGS[@]}")"
  if [[ -z "$text" ]]; then
    text="Answer using the provided file and directory context."
  fi

  if comai_answer_local_file_fact "$text"; then
    return 0
  fi

  if comai_answer_file_contains "$text"; then
    return 0
  fi

  if comai_answer_file_errors "$text"; then
    return 0
  fi

  if comai_answer_file_description "$text"; then
    return 0
  fi

  if ! comai_local_ai_ready; then
    comai_error "Local AI API is not responding at ${COMAI_API_BASE}."
    comai_error "Start it with: systemctl --user start comai-localai.service"
    comai_error "Or run: ${COMAI_AI_DIR}/start.sh"
    return 1
  fi

  dir_context=""
  if comai_wants_directory_context "$text"; then
    dir_context="$(comai_directory_context)"
  fi

  files="$(comai_file_context)"
  prompt="$(comai_ai_prompt "$text" "$dir_context" "$files")"
  comai_model_note
  comai_ask_ai "$prompt"
}

comai_main "$@"
